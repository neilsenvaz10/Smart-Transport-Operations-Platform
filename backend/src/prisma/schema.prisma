datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  fleet_manager
  driver
  safety_officer
  financial_analyst
}

enum UserStatus {
  active
  inactive
  suspended
  pending_invite
}

enum VehicleStatus {
  available
  on_trip
  in_shop
  retired
}

enum DriverStatus {
  available
  on_trip
  off_duty
  suspended
}

enum TripStatus {
  draft
  dispatched
  completed
  cancelled
}

enum MaintenanceStatus {
  active
  closed
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  passwordHash    String
  name            String
  phone           String?
  role            Role
  status          UserStatus        @default(active)
  lastLogin       DateTime?
  isFirstLogin    Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  drivers         Driver[]          @relation("UserDriver")
  trips           Trip[]            @relation("UserTrips")
  maintenances    MaintenanceLog[]  @relation("UserMaintenances")
  fuelLogs        FuelLog[]         @relation("UserFuelLogs")
  expenses        Expense[]         @relation("UserExpenses")
}

model Vehicle {
  id                 String           @id @default(uuid())
  registrationNumber String           @unique
  nameModel          String
  type               String // e.g., Box Truck, Flatbed, Van
  maxLoadCapacity    Float // in kg
  odometer           Float            @default(0.0) // in km
  acquisitionCost    Float
  status             VehicleStatus    @default(available)
  region             String? // Nullable region
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  trips              Trip[]
  maintenances       MaintenanceLog[]
  expenses           Expense[]
  fuelLogs           FuelLog[]
}

model Driver {
  id              String       @id @default(uuid())
  userId          String? // Nullable if driver does not have user access
  user            User?        @relation("UserDriver", fields: [userId], references: [id])
  name            String
  licenseNumber   String       @unique
  licenseCategory String
  licenseExpiry   DateTime
  contactNumber   String
  safetyScore     Float        @default(100.0)
  status          DriverStatus @default(available)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  trips           Trip[]
}

model Trip {
  id              String      @id @default(uuid())
  source          String
  destination     String
  cargoWeight     Float // in kg
  plannedDistance Float // in km
  finalOdometer   Float? // Filled on completion
  fuelConsumed    Float? // Filled on completion
  revenue         Float? // Needed for ROI
  status          TripStatus  @default(draft)
  createdById     String?
  createdBy       User?       @relation("UserTrips", fields: [createdById], references: [id])
  vehicleId       String
  vehicle         Vehicle     @relation(fields: [vehicleId], references: [id])
  driverId        String
  driver          Driver      @relation(fields: [driverId], references: [id])
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  fuelLogs        FuelLog[]
}

model MaintenanceLog {
  id              String            @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id])
  type            String
  technician      String?
  description     String
  cost            Decimal           @db.Decimal(12, 2)
  startDate       DateTime
  expectedEndDate DateTime?
  status          MaintenanceStatus @default(active)
  openedAt        DateTime          @default(now())
  closedAt        DateTime?
  createdById     String?
  createdBy       User?             @relation("UserMaintenances", fields: [createdById], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model FuelLog {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  tripId      String?
  trip        Trip?    @relation(fields: [tripId], references: [id])
  liters      Float
  cost        Float
  logDate     DateTime
  createdById String?
  createdBy   User?    @relation("UserFuelLogs", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  type        String // e.g. Toll, Misc
  amount      Float
  expenseDate DateTime
  notes       String?
  createdById String?
  createdBy   User?    @relation("UserExpenses", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

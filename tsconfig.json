{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./backend",
    "paths": {
      "@prisma/client": ["node_modules/@prisma/client"],
      "*": ["node_modules/*", "src/*"]
    }
  },
  "include": ["backend/src/**/*"]
}
